{
  "name": "seo-image-optimizer",
  "version": "1.0.2",
  "description": "Automatic SEO meta tags and image optimization for modern web apps",

  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",

  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },

  "repository": {
    "type": "git",
    "url": "https://github.com/yaredabebe/seo-image-optimizer.git"
  },

  "homepage": "https://github.com/yaredabebe/seo-image-optimizer#readme",

  "bugs": {
    "url": "https://github.com/yaredabebe/seo-image-optimizer/issues"
  },

  "files": [
    "dist",
    "README.md"
  ],

  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "prepublishOnly": "npm run build"
  },

  "keywords": [
    "seo",
    "meta-tags",
    "open-graph",
    "image-optimization",
    "typescript",
    "nextjs",
    "react"
  ],

  "author": "Yared Abebe",
  "license": "MIT",

  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },

  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },

  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}